# CordCloud 自动登录配置
CORDCLOUD_EMAIL=your_cordcloud_email@example.com
CORDCLOUD_PASSWORD=your_password

# POP3 邮箱配置（用于接收验证码）
POP3_HOST=pop.example.com
POP3_PORT=995
POP3_USE_SSL=true
POP3_USERNAME=your_pop3_username
POP3_PASSWORD=your_pop3_password
POP3_SCAN_LIMIT=10

# SMTP 配置（用于发送签到结果通知，自己发给自己）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=your_qq_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code

# 浏览器配置
USE_PERSISTENT_CONTEXT=true
PERSISTENT_PROFILE_DIR=./cloak_profile
HEADLESS=false

# 调试配置
SAVE_HTML=true
